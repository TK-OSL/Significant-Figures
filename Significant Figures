                    placeholder: "หรือพิมพ์ตัวเลขที่นี่...",
                    error: "กรุณาระบุตัวเลขที่ถูกต้อง (เช่น 12.34)",
                    rule_0: "<li>ตัวเลขนี้มีแต่เลขศูนย์ โดยหลักการแล้วเลขศูนย์ตัวเดียวอาจนับเป็นเลขนัยสำคัญ 1 ตัวถ้าได้จากการวัด แต่มักมีความกำกวม ในที่นี้จะนับศูนย์ตัวแรกเป็น 1 ตัว</li>",
                    rule_1: `<li><span class="font-semibold text-slate-800">กฎข้อ 1:</span> พบตัวเลขที่ไม่ใช่ศูนย์ ตัวเลขเหล่านี้เป็น <strong>เลขนัยสำคัญเสมอ</strong></li>`,
                    rule_2: `<li><span class="font-semibold text-slate-800">กฎข้อ 2:</span> พบเลขศูนย์อยู่ระหว่างตัวเลขที่ไม่ใช่ศูนย์ เลขศูนย์เหล่านี้ <strong>เป็นเลขนัยสำคัญ</strong></li>`,
                    rule_3: `<li><span class="font-semibold text-slate-800">กฎข้อ 3:</span> พบเลขศูนย์อยู่ด้านหน้า ทำหน้าที่บอกตำแหน่งทศนิยมเท่านั้น และ <strong>ไม่เป็นเลขนัยสำคัญ</strong></li>`,
                    rule_4_dec: `<li><span class="font-semibold text-slate-800">กฎข้อ 4:</span> พบเลขศูนย์ต่อท้าย <em>และ</em> มีจุดทศนิยม บ่งบอกถึงความละเอียดในการวัด และ <strong>เป็นเลขนัยสำคัญ</strong></li>`,
                    rule_4_nodec: `<li><span class="font-semibold text-slate-800">กฎข้อ 4:</span> พบเลขศูนย์ต่อท้าย แต่ <em>ไม่มี</em> จุดทศนิยม มักเป็นเพียงตัวรักษาตำแหน่ง และ <strong>ไม่เป็นเลขนัยสำคัญ</strong></li>`
                }
            };

            // --- Language Switching Logic ---
            function setLanguage(lang) {
                htmlTag.setAttribute('lang', lang);
                
                // Update button styles
                if (lang === 'en') {
                    btnEn.classList.add('bg-white', 'shadow-sm', 'text-primary');
                    btnEn.classList.remove('text-slate-500', 'hover:text-slate-800', 'bg-transparent');
                    
                    btnTh.classList.remove('bg-white', 'shadow-sm', 'text-primary');
                    btnTh.classList.add('text-slate-500', 'hover:text-slate-800', 'bg-transparent');
                } else {
                    btnTh.classList.add('bg-white', 'shadow-sm', 'text-primary');
                    btnTh.classList.remove('text-slate-500', 'hover:text-slate-800', 'bg-transparent');
                    
                    btnEn.classList.remove('bg-white', 'shadow-sm', 'text-primary');
                    btnEn.classList.add('text-slate-500', 'hover:text-slate-800', 'bg-transparent');
                }

                // Update dynamic input placeholder
                userInputNumber.placeholder = i18n[lang].placeholder;

                // Re-render analysis if there is a number currently displayed
                if (currentNumberString !== "" && !resultsContainer.classList.contains('hidden')) {
                    const analysis = analyzeSigFigs(currentNumberString, lang);
                    displayResults(analysis, false); // false = don't animate again
                }
            }

            btnEn.addEventListener('click', () => setLanguage('en'));
            btnTh.addEventListener('click', () => setLanguage('th'));

            // --- Number Generation Logic ---
            function generateRandomNumber() {
                const types = ['integer', 'decimal_leading_zeros', 'decimal_trailing_zeros', 'scientific_notation_like', 'exact_zeros'];
                const type = types[Math.floor(Math.random() * types.length)];
                
                let numStr = "";
                
                switch(type) {
                    case 'integer':
                        numStr = Math.floor(Math.random() * 10000).toString();
                        if (Math.random() > 0.5) numStr += "00"; 
                        break;
                    case 'decimal_leading_zeros':
                        numStr = "0.0" + "0".repeat(Math.floor(Math.random() * 3)) + (Math.floor(Math.random() * 900) + 10).toString();
                        break;
                    case 'decimal_trailing_zeros':
                        numStr = (Math.random() * 100).toFixed(2 + Math.floor(Math.random() * 3));
                        break;
                    case 'scientific_notation_like':
                         numStr = (Math.random() * 10).toFixed(3);
                         break;
                    case 'exact_zeros':
                         numStr = (Math.floor(Math.random() * 90) + 10).toString() + ".0";
                         break;
                }
                
                if(parseFloat(numStr) === 0 && !numStr.includes('.')) numStr = "0";
                return numStr;
            }

            // --- Core Logic: Analyze Significant Figures ---
            function analyzeSigFigs(numberString, lang = htmlTag.getAttribute('lang')) {
                let cleanStr = numberString.trim();
                const dict = i18n[lang];
                
                if (!/^-?[0-9]*\.?[0-9]+$/.test(cleanStr) && !/^-?[0-9]+\.?[0-9]*$/.test(cleanStr)) {
                    return { error: dict.error };
                }

                let str = cleanStr.replace(/^-/, ''); 
                let hasDecimal = str.includes('.');
                let steps = [];
                let sigFigIndices = new Set();
                
                let digitsOnly = str.replace('.', '');
                let firstNonZeroIdx = -1;
                let lastNonZeroIdx = -1;

                for (let i = 0; i < digitsOnly.length; i++) {
                    if (digitsOnly[i] !== '0') {
                        if (firstNonZeroIdx === -1) firstNonZeroIdx = i;
                        lastNonZeroIdx = i;
                    }
                }

                // Rule implementations using dictionary
                if (firstNonZeroIdx === -1) {
                     steps.push(dict.rule_0);
                     let idx = str.indexOf('0');
                     if(idx !== -1) sigFigIndices.add(idx);
                     
                     return {
                        original: cleanStr,
                        processedStr: str,
                        sigFigIndices: sigFigIndices,
                        steps: steps,
                        count: 1
                    };
                }

                // Rule 1
                steps.push(dict.rule_1);
                
                // Rule 2
                let hasMiddleZeros = false;
                for (let i = firstNonZeroIdx; i <= lastNonZeroIdx; i++) {
                    if (digitsOnly[i] === '0') {
                        hasMiddleZeros = true;
                    }
                }
                if (hasMiddleZeros) {
                    steps.push(dict.rule_2);
                }

                // Rule 3
                if (firstNonZeroIdx > 0) {
                    steps.push(dict.rule_3);
                }

                // Rule 4
                let hasTrailingZeros = lastNonZeroIdx < digitsOnly.length - 1;
                if (hasTrailingZeros) {
                    if (hasDecimal) {
                        steps.push(dict.rule_4_dec);
                    } else {
                        steps.push(dict.rule_4_nodec);
                    }
                }

                let digitCounter = 0;
                let count = 0;
                
                for (let i = 0; i < str.length; i++) {
                    if (str[i] === '.') continue; 

                    let isSig = false;

                    if (digitCounter >= firstNonZeroIdx && digitCounter <= lastNonZeroIdx) {
                        isSig = true;
                    } 
                    else if (digitCounter > lastNonZeroIdx && hasDecimal) {
                        isSig = true;
                    }

                    if (isSig) {
                        sigFigIndices.add(i);
                        count++;
                    }
                    digitCounter++;
                }

                return {
                    original: cleanStr,
                    processedStr: str, 
                    hasNegative: cleanStr.startsWith('-'),
                    sigFigIndices: sigFigIndices,
                    steps: steps,
                    count: count
                };
            }

            // --- UI Update Logic ---
            function displayResults(analysis, animate = true) {
                if (analysis.error) {
                    alert(analysis.error); 
                    return;
                }

                currentNumberString = analysis.original;

                initialState.classList.add('hidden');
                resultsContainer.classList.remove('hidden');
                
                if(animate) {
                    resultsContainer.classList.remove('fade-in');
                    void resultsContainer.offsetWidth; // trigger reflow
                    resultsContainer.classList.add('fade-in');
                }

                numberDisplay.innerHTML = '';
                explanationList.innerHTML = '';
                
                if(analysis.hasNegative) {
                     const minusSpan = document.createElement('span');
                     minusSpan.textContent = '-';
                     minusSpan.className = 'text-slate-800 mx-[1px]';
                     numberDisplay.appendChild(minusSpan);
                }

                for (let i = 0; i < analysis.processedStr.length; i++) {
                    const char = analysis.processedStr[i];
                    const span = document.createElement('span');
                    span.textContent = char;
                    span.className = 'inline-block mx-[2px] highlight-digit ';
                    
                    if (char === '.') {
                        span.className += 'text-slate-800 font-bold';
                    } else if (analysis.sigFigIndices.has(i)) {
                        span.className += 'significant border-b-4 border-green-500 pb-1';
                    } else {
                        span.className += 'non-significant';
                    }
                    
                    numberDisplay.appendChild(span);
                }

                analysis.steps.forEach((stepHTML, index) => {
                    const li = document.createElement('div');
                    li.innerHTML = stepHTML;
                    if(animate) {
                        li.className = 'fade-in';
                        li.style.animationDelay = `${index * 0.1}s`;
                    }
                    explanationList.appendChild(li);
                });

                if (animate) {
                    finalCount.textContent = '...';
                    setTimeout(() => {
                        finalCount.textContent = analysis.count;
                        finalCount.classList.add('scale-110', 'text-green-600', 'transition-transform');
                        setTimeout(() => finalCount.classList.remove('scale-110'), 200);
                    }, 300);
                } else {
                    finalCount.textContent = analysis.count;
                }
            }

            // --- Event Listeners ---
            generateBtn.addEventListener('click', () => {
                const numStr = generateRandomNumber();
                userInputNumber.value = numStr; 
                const analysis = analyzeSigFigs(numStr);
                displayResults(analysis);
            });

            checkUserNumBtn.addEventListener('click', () => {
                const val = userInputNumber.value;
                if(val) {
                    const analysis = analyzeSigFigs(val);
                    displayResults(analysis);
                }
            });

            userInputNumber.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    checkUserNumBtn.click();
                }
            });
            
            userInputNumber.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9.-]/g, '');
            });

            // Set initial language explicitly to ensure correct state load
            setLanguage('en');
        });
    </script>
</body>
</html>
